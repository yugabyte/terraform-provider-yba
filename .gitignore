# Test exclusions
!command/test-fixtures/**/*.tfstate
!command/test-fixtures/**/.terraform/

# Keep windows files with windows line endings
*.winfile eol=crlf

local/

# YBA license file used by acctest fixtures (secret)
*.lic

# GCP service-account key fetched for local acctest runs (secret)
*-creds.json
.gcp-creds.json

# Test env written by `make acctest-env` (secret: SA key + API token)
acctest/env*

# SSH keypair the azure fixture generates in-apply when ssh_private_key_file=""
acctest/*/.ssh-*
