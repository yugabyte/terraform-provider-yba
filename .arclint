{
    "linters": {
        "golangci-lint": {
            "type": "script-and-regex",
            "include": "(\\.go$)",
            "exclude": [
                "(^docs/)",
                "(^examples/)",
                "(^modules/)"
            ],
            "script-and-regex.script": "make lint-go",
            "script-and-regex.regex": "/^(?P<file>[^:\\n]+\\.go):(?P<line>\\d+):(?P<char>\\d+):\\s+(?P<message>.+?)\\s+\\((?P<name>[^)]+)\\)\\s*$/m"
        }
    }
}
